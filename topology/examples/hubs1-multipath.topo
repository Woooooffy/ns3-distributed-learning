module hub_spoke(N){
	node sw type=switch;
	for i in (1, N){
		node n{i} type=gpu;
		link n{i} sw bandwidth=125[Gbps] latency=300[ns];
		link sw n{i} bandwidth=125[Gbps] latency=300[ns];
	}
}

module main(){
	use hub_spoke(4) as c1;
	use hub_spoke(4) as c2;
	for i in (1, 4){
		node sw{i} type=switch;
	}
	link c1.sw sw1 bandwidth=9[Gbps] latency=1500[ns];
	link c2.sw sw3 bandwidth=9[Gbps] latency=1500[ns];

	link sw1 sw4 bandwidth=9[Gbps] latency=1500[ns];
	link sw1 sw2 bandwidth=9[Gbps] latency=1500[ns];
	link sw2 sw3 bandwidth=9[Gbps] latency=1500[ns];
	link sw3 sw4 bandwidth=9[Gbps] latency=1500[ns];
}
